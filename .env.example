# MODE shared env template (placeholders only)
# Staging default for MAX_ACTIVE_CHAT_STREAMS_PER_INSTANCE is 15.
# Production default for MAX_ACTIVE_CHAT_STREAMS_PER_INSTANCE is 10.

APP_ENV=<development_or_staging_or_production>
EXPO_PUBLIC_API_BASE_URL=<https://api.example.com_or_local_url>
EXPO_PUBLIC_SUPABASE_URL=<https://your-project-ref.supabase.co>
EXPO_PUBLIC_SUPABASE_ANON_KEY=<supabase_anon_key_public>
EXPO_PUBLIC_SUPABASE_REDIRECT_URL=<mode://auth/callback>

# Validated safe cap per launch gate 2026-05-17; raise to 15+ pending provider tier audit.
MAX_ACTIVE_CHAT_STREAMS_PER_INSTANCE=<15_for_staging_or_10_for_production>
USE_FAKE_PROVIDER=<false>
