{
  "name": "mode",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "node scripts/dev_launcher.js",
    "start": "expo start",
    "start:clean": "expo start --go -c",
    "start:dev-client": "expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev-client": "expo run:ios --device --no-install --no-bundler",
    "web": "expo start --web",
    "backend:dev": "cd backend && ./venv/bin/python main.py",
    "backend:check": "node scripts/backend_health_check.js",
    "codex:check": "node scripts/codex_prompt_check.js",
    "launch:apply-migrations": "cd backend && ./venv/bin/python scripts/apply_launch_gate_migrations.py",
    "launch:verify": "cd backend && ./venv/bin/python scripts/launch_gate_staging_verification.py",
    "lint": "eslint src lib App.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage",
    "security:secrets": "./scripts/security_scan_secrets.sh",
    "release:security": "./scripts/release_security.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.99.3",
    "expo": "~55.0.23",
    "expo-asset": "~55.0.16",
    "expo-auth-session": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.32",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-secure-store": "~55.0.13",
    "expo-web-browser": "~55.0.15",
    "lucide-react-native": "^1.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.38.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "react-test-renderer": "^19.2.0"
  },
  "private": true
}
