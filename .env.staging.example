# MODE staging/local security env template (placeholders only)
# Copy to .env.staging and replace placeholders with staging/local values.
# Do not commit .env.staging.

APP_ENV=<development_or_staging>
OPENAI_API_KEY=<openai_api_key_staging_or_dummy>
SUPABASE_URL=<https://your-staging-project-ref.supabase.co>
SUPABASE_ANON_KEY=<supabase_anon_key_staging_secret>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role_key_staging_secret>
MODE_SECURITY_DATABASE_URL=<postgresql://postgres:<password>@<staging-db-host>:5432/postgres>

EXPO_PUBLIC_SUPABASE_URL=<https://your-staging-project-ref.supabase.co>
EXPO_PUBLIC_SUPABASE_ANON_KEY=<supabase_anon_key_staging_public>
EXPO_PUBLIC_API_BASE_URL=<https://api.staging.your-domain.com>
EXPO_PUBLIC_SUPABASE_REDIRECT_URL=<mode://auth/callback>

MODE_IOS_IPA_PATH=<build/ios/staging.ipa_or_leave_unset_in_local_mode>
MODE_IOS_INFO_PLIST_PATH=<ios/YourApp/Info.plist_optional>

RATE_LIMIT_BACKEND=<memory_or_postgres>
STARTUP_GUARD_ENABLED=<true>
AUTH_PASSWORD_PROXY_ENABLED=<true>
ACCOUNT_DELETION_ENABLED=<true>
ACCOUNT_DELETION_CONTRACT_ENFORCED=<true>
PERSONAL_DATA_INVENTORY_PATH=<security/personal_data_inventory.json>
ACCOUNT_DELETION_ACTIVE_SINK_CATEGORIES=<file_storage,retrieval_caches,analytics_events>
ACCOUNT_DELETION_DISABLED_SINK_CATEGORIES=<vector_indexes,embedding_stores,logs,notification_providers,email_providers,ai_memory_retrieval_systems>
ATLAS_ENABLED=<true>
ATLAS_BACKGROUND_LEARNING_ENABLED=<true>
ATLAS_REVIEW_REQUIRED=<true>
ATLAS_TRAINER_DELETION_LEARNING_ENABLED=<true>
ATLAS_TRAINER_AI_MANAGER_ENABLED=<true>
TRAINER_AI_LEARNING_ENABLED=<true>
TRAINER_AI_REVIEW_REQUIRED=<true>
ATLAS_RUNTIME_ENABLED=<false>
ATLAS_GENERIC_COACH_ENABLED=<false>
ATLAS_ADMIN_EMAIL_ALLOWLIST=<admin@example.com_or_empty_to_disable>
EXPO_PUBLIC_ATLAS_ADMIN_REVIEW_ENABLED=<false>

MODE_STORAGE_ORPHAN_THRESHOLD=<0>
MODE_STORAGE_CLEANUP_MAX_HEARTBEAT_AGE_MINUTES=<30>
MODE_STORAGE_CLEANUP_EXPECTED_INTERVAL_MINUTES=<15>
